# Database
POSTGRES_DB=signum
POSTGRES_USER=signum
POSTGRES_PASSWORD=signum_pass
DATABASE_URL=postgresql+asyncpg://signum:signum_pass@localhost:5432/signum
DATABASE_URL_SYNC=postgresql://signum:signum_pass@localhost:5432/signum

# API
ENVIRONMENT=development
API_KEY=dev-api-key-change-in-production
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=DEBUG

# Redis
REDIS_URL=redis://localhost:6379/0

# Scraping (optional)
FIRECRAWL_API_KEY=

# Production overrides (set these in your environment, NOT in .env):
#   POSTGRES_PASSWORD=<strong-secret>
#   API_KEY=<strong-secret>
#   CORS_ORIGINS=https://yourdomain.com
#   ENVIRONMENT=production
